rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'role', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['user', 'creator', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidAgent(data) {
      return data.keys().hasAll(['name', 'description', 'creatorId', 'price', 'instructions', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.description is string && data.description.size() <= 1000 &&
             data.creatorId == request.auth.uid &&
             data.price is number && data.price >= 0 &&
             data.createdAt == request.time;
    }

    function isValidDeployment(data) {
      return data.keys().hasAll(['userId', 'agentId', 'status', 'purchasedAt']) &&
             data.userId == request.auth.uid &&
             data.status in ['active', 'paused', 'stopped'] &&
             data.purchasedAt == request.time;
    }

    // Collection Rules

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.role == 'creator'; // Allow listing creators for the marketplace
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role != 'admin';
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio']) &&
                      incoming().displayName is string && incoming().displayName.size() <= 100;
    }

    match /agents/{agentId} {
      allow read: if true; // Marketplace is public
      allow create: if isVerified() && isValidAgent(incoming());
      allow update: if isOwner(existing().creatorId) && 
                      isValidAgent(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'instructions', 'imageUrl', 'category', 'capabilities']) &&
                      incoming().creatorId == existing().creatorId;
      allow delete: if isOwner(existing().creatorId);
    }

    match /deployments/{deploymentId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isVerified() && isValidDeployment(incoming()) && exists(/databases/$(database)/documents/agents/$(incoming().agentId));
      allow update: if isOwner(existing().userId) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'lastRun']) &&
                      incoming().status in ['active', 'paused', 'stopped'];
      allow delete: if isOwner(existing().userId);
    }

    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (isOwner(resource.data.buyerId) || isOwner(resource.data.sellerId));
      allow create: if isVerified() && 
                      incoming().buyerId == request.auth.uid &&
                      incoming().timestamp == request.time &&
                      existsAfter(/databases/$(database)/documents/deployments/$(transactionId)); // Use same ID or check related deployment
    }
  }
}
